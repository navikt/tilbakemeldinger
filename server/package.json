{
    "name": "tilbakemeldinger-server",
    "version": "4.10.5",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node ./dist/server/server/src/server.js",
        "dev": "pnpm run build && concurrently \"tsc -w\" \"nodemon -w ./dist/server ./dist/server/server/src/server.js\""
    },
    "dependencies": {
        "compression": "1.8.1",
        "csp-header": "6.3.1",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "express-rate-limit": "8.4.1",
        "jwt-decode": "4.0.0",
        "lru-cache": "11.3.5",
        "node-cache": "5.1.2",
        "openid-client": "5.6.5"
    },
    "devDependencies": {
        "@types/compression": "1.8.1",
        "@types/express": "5.0.6",
        "@types/node": "25.6.0",
        "concurrently": "9.2.1",
        "nodemon": "3.1.14"
    },
    "nodemonConfig": {
        "delay": 500
    }
}
