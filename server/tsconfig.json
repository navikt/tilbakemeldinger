{
    "compilerOptions": {
        "jsx": "react",
        "allowJs": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "lib": ["dom", "es2022"],
        "moduleResolution": "nodenext",
        "module": "nodenext",
        "outDir": "dist/server",
        "rootDir": "..",
        "strict": true,
        "target": "ES2022",
        "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts"]
}
