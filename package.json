{
    "name": "tilbakemeldinger",
    "version": "4.10.5",
    "private": true,
    "author": "Nav",
    "license": "MIT",
    "homepage": "/person/kontakt-oss/tilbakemeldinger",
    "type": "module",
    "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
    "scripts": {
        "build": "pnpm run build:client && pnpm run build:ssr && pnpm run build:server",
        "build:client": "vite build --outDir ./server/dist/client",
        "build:ssr": "vite build --outDir ./server/src/_ssr-dist --ssr src/main-server.tsx",
        "build:server": "pnpm --filter tilbakemeldinger-server run build",
        "analyze-bundle": "ANALYZE=true pnpm run build:client",
        "start": "node server/dist/server/server/src/server.js",
        "start-local": "cp .env.local-prod .env && node server/dist/server/server/src/server.js",
        "lint": "pnpm run lint:eslint && pnpm run lint:types",
        "lint:eslint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" \"common/**/*.{js,jsx,ts,tsx}\" \"server/src/**/*.{js,jsx,ts,tsx}\"",
        "lint:types": "tsc --noEmit && pnpm --filter tilbakemeldinger-server exec tsc --noEmit",
        "decorator-local": "docker compose up",
        "dev-prepare": "node preact-compat-symlinks.js && cp .env.development .env",
        "dev": "pnpm run dev-prepare && pnpm --filter tilbakemeldinger-server run dev",
        "prepare": "husky || true",
        "test": "node --experimental-vm-modules $(pnpm root)/jest/bin/jest.js --config jest.config.js",
        "test:watch": "node --experimental-vm-modules $(pnpm root)/jest/bin/jest.js --config jest.config.js --watch",
        "test:coverage": "node --experimental-vm-modules $(pnpm root)/jest/bin/jest.js --config jest.config.js --coverage"
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.10.2",
        "@navikt/ds-css": "8.10.2",
        "@navikt/ds-react": "8.10.2",
        "@navikt/fnrvalidator": "1.3.3",
        "@navikt/nav-dekoratoren-moduler": "3.7.1",
        "@preact/compat": "18.3.2",
        "date-fns": "4.1.0",
        "downshift": "9.3.2",
        "preact": "10.29.1",
        "preact-render-to-string": "6.6.7",
        "react": "npm:@preact/compat@18.3.2",
        "react-dom": "npm:@preact/compat@18.3.2",
        "react-helmet-async": "3.0.0",
        "react-hook-form": "7.74.0",
        "react-intl": "6.6.8",
        "react-router": "7.14.2",
        "react-router-dom": "7.14.2",
        "vite": "8.0.9",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "9.39.4",
        "@preact/preset-vite": "2.10.5",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/preact": "3.2.4",
        "@types/fetch-mock": "7.3.8",
        "@types/jest": "30.0.0",
        "@types/node": "25.6.0",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.5",
        "@typescript-eslint/eslint-plugin": "8.59.0",
        "@typescript-eslint/parser": "8.59.0",
        "eslint": "9.38.0",
        "eslint-plugin-react": "7.37.5",
        "fetch-mock": "11.1.5",
        "globals": "17.5.0",
        "husky": "9.1.7",
        "identity-obj-proxy": "3.0.0",
        "jest": "30.3.0",
        "jest-environment-jsdom": "30.3.0",
        "lint-staged": "16.4.0",
        "prettier": "3.8.3",
        "rollup-plugin-visualizer": "7.0.1",
        "sass": "1.99.0",
        "ts-jest": "29.4.9",
        "ts-node": "10.9.2",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,css,scss,md}": "prettier --write",
        "*.{js,jsx,ts,tsx}": "eslint --fix"
    }
}
